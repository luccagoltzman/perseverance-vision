# Clima (InSight) — https://api.nasa.gov/
VITE_NASA_API_KEY=DEMO_KEY

# Fotos dos rovers (obrigatório — API NASA Mars Photos está fora do ar)
# Chave gratuita em https://marsvista.dev/signin
VITE_MARSVISTA_API_KEY=

# WebSocket multiplayer — deixe vazio em dev (proxy Vite em /ws).
# Produção (Vercel): use wss:// e termine com /ws — ex.:
# VITE_MULTIPLAYER_WS_URL=wss://perseverance-vision.fly.dev/ws
